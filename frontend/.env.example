# Oracle backend origin used by Next rewrites during local development.
DASHBOARD_BACKEND_ORIGIN=http://127.0.0.1:3456

# Public backend origin used when /app renders the HTML control console.
DASHBOARD_PUBLIC_API_URL=http://127.0.0.1:3456

# Public frontend origin for metadata and canonical URLs.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
